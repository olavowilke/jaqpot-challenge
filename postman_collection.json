{
  "info": {
    "name": "Jaqpot Casino + Provider",
    "_postman_id": "8a4f0c1a-1111-2222-3333-444455556666",
    "description": "Manual testing collection for the Jaqpot casino + provider services. HMAC-signed requests use a pre-request script that signs the raw body with the matching secret and sets the appropriate header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "casinoBaseUrl", "value": "http://localhost:3000" },
    { "key": "providerBaseUrl", "value": "http://localhost:3000" },
    { "key": "casinoSecret", "value": "casino-dev-secret" },
    { "key": "providerSecret", "value": "provider-dev-secret" },
    { "key": "userId", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "gameId", "value": "44444444-4444-4444-4444-444444444444" },
    { "key": "currency", "value": "USD" },
    { "key": "sessionToken", "value": "" },
    { "key": "providerSessionId", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "providerInternalGameId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{casinoBaseUrl}}/health", "host": ["{{casinoBaseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "Casino - launchGame (no HMAC)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "if (j.sessionToken) pm.collectionVariables.set('sessionToken', j.sessionToken);",
              "if (j.providerSessionId) pm.collectionVariables.set('providerSessionId', j.providerSessionId);",
              "if (j.customerId) pm.collectionVariables.set('customerId', j.customerId);",
              "if (j.providerInternalGameId) pm.collectionVariables.set('providerInternalGameId', j.providerInternalGameId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"gameId\": \"{{gameId}}\",\n  \"currency\": \"{{currency}}\"\n}"
        },
        "url": {
          "raw": "{{casinoBaseUrl}}/casino/launchGame",
          "host": ["{{casinoBaseUrl}}"],
          "path": ["casino", "launchGame"]
        }
      }
    },
    {
      "name": "Casino - getBalance (HMAC)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.request.body && pm.request.body.raw ? pm.request.body.raw : '';",
              "const resolved = pm.variables.replaceIn(body);",
              "const sig = CryptoJS.HmacSHA256(resolved, pm.collectionVariables.get('casinoSecret')).toString(CryptoJS.enc.Hex);",
              "pm.request.headers.upsert({ key: 'x-casino-signature', value: sig });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"sessionToken\":\"{{sessionToken}}\"}"
        },
        "url": {
          "raw": "{{casinoBaseUrl}}/casino/getBalance",
          "host": ["{{casinoBaseUrl}}"],
          "path": ["casino", "getBalance"]
        }
      }
    },
    {
      "name": "Casino - debit (HMAC)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.collectionVariables.get('debitTxId')) {",
              "  pm.collectionVariables.set('debitTxId', 'tx-debit-' + Date.now());",
              "}",
              "const body = pm.request.body && pm.request.body.raw ? pm.request.body.raw : '';",
              "const resolved = pm.variables.replaceIn(body);",
              "const sig = CryptoJS.HmacSHA256(resolved, pm.collectionVariables.get('casinoSecret')).toString(CryptoJS.enc.Hex);",
              "pm.request.headers.upsert({ key: 'x-casino-signature', value: sig });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"transactionId\":\"{{debitTxId}}\",\"sessionToken\":\"{{sessionToken}}\",\"amount\":500,\"roundId\":\"round-1\"}"
        },
        "url": {
          "raw": "{{casinoBaseUrl}}/casino/debit",
          "host": ["{{casinoBaseUrl}}"],
          "path": ["casino", "debit"]
        }
      }
    },
